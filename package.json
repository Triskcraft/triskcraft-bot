{
    "name": "bot-inactividad",
    "version": "1.0.0",
    "description": "Discord bot para gestionar periodos de inactividad y estadisticas de roles.",
    "type": "module",
    "packageManager": "pnpm@11.15.0",
    "main": "src/index.ts",
    "scripts": {
        "start": "node src/index.ts",
        "lint": "eslint .",
        "build": "tsc",
        "dev": "node --watch src/index.ts",
        "format:check": "prettier --check .",
        "format:fix": "prettier --write ."
    },
    "imports": {
        "#/*": "./src/*"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1090.0",
        "@aws-sdk/lib-storage": "3.1090.0",
        "@eliyya/flagged-bitfield": "1.1.1",
        "@js-temporal/polyfill": "0.5.1",
        "@triskcraft/api-types": "1.2.1",
        "@triskcraft/db": "0.1.1",
        "argon2": "0.44.0",
        "busboy": "1.6.0",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "discord.js": "14.27.0",
        "express": "5.2.1",
        "jose": "6.2.3",
        "luxon": "3.7.2",
        "neverthrow": "8.2.0",
        "pino": "10.3.1",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@eslint/json": "2.0.1",
        "@types/busboy": "1.5.4",
        "@types/cookie-parser": "1.4.10",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/luxon": "3.7.2",
        "@types/multer": "2.2.0",
        "@types/node": "24.13.3",
        "eslint": "10.7.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "globals": "17.7.0",
        "pino-pretty": "13.1.3",
        "prettier": "3.9.5",
        "typescript": "6.0.2",
        "typescript-eslint": "8.64.0"
    },
    "engines": {
        "node": ">=24.14"
    }
}
