{
    "name": "bot-inactividad",
    "version": "1.0.0",
    "description": "Discord bot para gestionar periodos de inactividad y estadisticas de roles.",
    "type": "module",
    "packageManager": "pnpm@11.5.2",
    "main": "src/index.ts",
    "scripts": {
        "start": "node src/index.ts",
        "lint": "eslint .",
        "build": "prisma generate && tsc",
        "dev": "node --watch src/index.ts",
        "db:copy-prod": "prisma migrate reset && prisma generate && node scripts/copydb.ts"
    },
    "imports": {
        "#/*": "./src/*"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "3.1039.0",
        "@aws-sdk/lib-storage": "3.1038.0",
        "@eliyya/flagged-bitfield": "^1.1.1",
        "@js-temporal/polyfill": "0.5.1",
        "@prisma/adapter-pg": "7.8.0",
        "@prisma/client": "7.8.0",
        "@triskcraft/api-types": "^1.2.1",
        "argon2": "0.44.0",
        "busboy": "1.6.0",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "discord.js": "14.26.3",
        "express": "5.2.1",
        "jose": "6.2.3",
        "luxon": "3.7.2",
        "neverthrow": "8.2.0",
        "pg": "8.20.0",
        "pino": "10.3.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@eslint/json": "1.2.0",
        "@types/busboy": "1.5.4",
        "@types/cookie-parser": "1.4.10",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/luxon": "3.7.1",
        "@types/multer": "2.1.0",
        "@types/node": "25.6.0",
        "eslint": "10.2.1",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "globals": "17.5.0",
        "pino-pretty": "13.1.3",
        "prisma": "7.8.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.1"
    },
    "engines": {
        "node": ">=24.14"
    }
}
